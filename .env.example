# ============================================================
# DonaRog App — Template configurazione ambiente
# ============================================================
# Copia questo file in .env e personalizzalo.
# Il file .env NON viene committato (vedi .gitignore).

# --- Database ---
# Per DB locale (con docker-compose.local-db.yml): DB_HOST=postgres
# Per DB esterno:                                   DB_HOST=192.168.1.100
DB_HOST=postgres
DB_PORT=5432
DB_NAME=donarogdb
DB_USER=donarog
DB_PASSWORD=CAMBIA_QUESTA_PASSWORD

# --- Server ---
# Imposta l'IP o dominio del server dove l'app è raggiungibile
# Esempi:
#   SERVER_HOST=192.168.1.50          (IP LAN)
#   SERVER_HOST=test.miodominio.it    (dominio)
#   SERVER_HOST=localhost             (locale)
SERVER_HOST=localhost

# --- Porte ---
API_PORT=44318
FRONTEND_PORT=4200

# --- Sicurezza ---
# Cambia questa passphrase in produzione
OPENIDDICT_CERT_PASSPHRASE=CAMBIA_QUESTA_PASSPHRASE

# --- Ambiente ---
# Staging | Production
ASPNETCORE_ENVIRONMENT=Staging
